# 0️⃣ 前置作業: 確認環境
# 確認你在家目錄或方便的資料夾
cd ~
mkdir -p snpEff
cd snpEff


# 1️⃣ 下載 SnpEff
wget https://downloads.sourceforge.net/project/snpeff/snpEff_latest_core.zip
unzip snpEff_latest_core.zip
cd snpEff
#此目錄結構應有snpEff.jar  SnpSift.jar  examples/  scripts/  snpEff.config


# 2️⃣ 手動建立 GRCh38 資料庫資料夾
cd ~/snpEff/data
mkdir -p GRCh38.113/sequences
mkdir -p GRCh38.113/genes

#此時目錄結構為
data/
└── GRCh38.109/
    ├── genes/
    └── sequences/


# 3️⃣ 下載必要檔案與解壓縮
# 下載 GTF + 解壓縮
cd ~/snpEff/data/GRCh38.113/genes
wget -c http://ftp.ensembl.org/pub/release-113/gtf/homo_sapiens/Homo_sapiens.GRCh38.113.gtf.gz
gunzip Homo_sapiens.GRCh38.113.gtf.gz
mv Homo_sapiens.GRCh38.dna.primary_assembly.fa sequences.fa

# 下載 DNA FASTA (~840MB) + 解壓縮
cd ~/snpEff/data/GRCh38.113/sequences
wget -c http://ftp.ensembl.org/pub/release-113/fasta/homo_sapiens/dna/Homo_sapiens.GRCh38.dna.primary_assembly.fa.gz
gunzip Homo_sapiens.GRCh38.dna.primary_assembly.fa.gz
mv Homo_sapiens.GRCh38.113.gtf genes.gtf

#資料結構
~/snpEff/
 ├─ snpEff.jar
 ├─ snpEff.config   ← 重要
 └─ data/
     └─ GRCh38.113/
         ├─ genes/
         │   └─ genes.gtf
         └─ sequences/
             └─ sequences.fa

#把genes.gtf.gz跟sequencce.fa直接拉到GRCh38.113下
cd ~/snpEff/data/GRCh38.113
mv genes/genes.gtf ./
mv sequences/sequences.fa ./
rm -r genes sequences

# 4️⃣ 設定snpEff.config
#在 ~/snpEff/snpEff.config 最底新增：
GRCh38.113.genome : Homo_sapiens_GRCh38.113
GRCh38.113.gtf : data/GRCh38.113/genes/genes.gtf
GRCh38.113.fa  : data/GRCh38.113/sequences/sequences.fa

echo "GRCh38.113.genome : Homo_sapiens_GRCh38.113" >> snpEff.config
echo "GRCh38.113.gtf : data/GRCh38.113/genes/genes.gtf" >> snpEff.config
echo "GRCh38.113.fa  : data/GRCh38.113/sequences/sequences.fa" >> snpEff.config
tail ~/snpEff/snpEff.config


# 5️⃣ 建立SnpEff資料庫
cd ~/snpEff
java -Xmx12g -jar snpEff.jar build -gtf22 -v GRCh38.113
#-gtf22 → 使用 GTF 轉錄本
#-v → verbose，看到處理進度
#正常輸出：會看到類似 10000 .... 20000 .... 等進度，代表正在 build
#自動產生snpEff.genes.txt, snpEff.contigs, snpEffVersion.txt在~/snpEff/data/GRCh38.109/


# 6️⃣ 對你的 resistant-specific VCF 做 annotation #做annotation的時候需要在snpEff安裝處
# 假設你的 VCF 在 ~/snpEff/resistant_specific.vcf
java -Xmx10g -jar snpEff.jar -v GRCh38.113 \
    -canon \
    -no-intergenic -no-intron -no-upstream -no-downstream -no-utr \
    -lof \
     ~/input.vcf > ~/ann/input.ann.vcf
#input.vcf → 你的 RNA-seq VCF；input.ann.vcf → SnpEff 加上註解的結果
#-canon → 只用 canonical transcript
#-no-intergenic -no-intron -no-upstream -no-downstream -no-utr → 只保留 coding/exonic
#-lof → 標記 LOF/NMD


# 7️⃣ 檢查結果
# 1. 確認檔案大小與內容
ls -lh ~/ann/input.ann.vcf
head ~/ann/input.ann.vcf
#看 EFF= 欄位，裡面會包含變異型態（missense, synonymous, stop_gained…）
#LOF/NMD 註解會加在 EFF= 或 LOF= 欄位

# 2. 用snpEff_summary.html查看註解統計
打開~/snpEff/snpEff_summary.html


