#4️⃣ 下載參考基因組 (第二次後可跳過)

#下載參考基因組 FASTA（hg38 / GRCh38, Ensembl release 113）
wget -c http://ftp.ensembl.org/pub/release-113/fasta/homo_sapiens/dna/Homo_sapiens.GRCh38.dna.primary_assembly.fa.gz  #載DNA 全基因組 FASTA（包含所有染色體與 scaffolds），fasta hg38,ensembl release113
wget -c http://ftp.ensembl.org/pub/release-113/gtf/homo_sapiens/Homo_sapiens.GRCh38.113.gtf.gz #下載基因註釋 GTF（對應到同樣的 Ensembl release 113）

###手動解壓縮FASTA跟GTP###

#產生索引與字典
samtools faidx Homo_sapiens.GRCh38.dna.primary_assembly.fa         #用 samtools 產生 FASTA index (.fai)
gatk CreateSequenceDictionary -R Homo_sapiens.GRCh38.dna.primary_assembly.fa -O Homo_sapiens.GRCh38.dna.primary_assembly.dict         #用 GATK / Picard 產生字典檔（.dict）

#建立reference資料夾
mkdir -p ~/reference
cd ~/reference
mkdir hg38_ensembl
mkdir hg38_ucsc

#在WSL主機下的reference/hg38_ensembl載hg38的fasta (1,2,3,X,Y,MT)
wget -c https://ftp.ensembl.org/pub/release-113/fasta/homo_sapiens/dna/Homo_sapiens.GRCh38.dna.primary_assembly.fa.gz #DNA primary assembly（GATK 可用）
ls -lh #檢查
gunzip Homo_sapiens.GRCh38.dna.primary_assembly.fa.gz #解壓縮
mv Homo_sapiens.GRCh38.dna.primary_assembly.fa hg38.fa #把名字換成hg38.fa
ls -lh hg38.fa #檢查
samtools faidx hg38.fa #建立 FASTA index（.fai）
ls -lh hg38.fa* #檢查
gatk CreateSequenceDictionary \
    -R hg38.fa \
    -O hg38.dict #建立 GATK 用的 sequence dictionary（.dict）
ls -lh #應該要可以看到三個檔案

#在WSL主機下的reference/hg38_ucsc載hg38的fasta (chr1, chr2....)
wget -c https://hgdownload.soe.ucsc.edu/goldenPath/hg38/bigZips/hg38.fa.gz
gunzip hg38.fa.gz
samtools faidx hg38.fa
gatk CreateSequenceDictionary -R hg38.fa -O hg38.dict
grep "^>" hg38.fa | head

##可以用來分辨reference現在用的hg38.fa是哪種contig
head -n 5 hg38.fa
#>chr:UCSC
#>1: Ensembl
##分辨.bam裡面的contig
samtools view -H ~/3_HNH3FDSX5_L4_dedup.bam | grep "^@SQ" | head





#5️⃣ BAM 檔前處理 (第二次開始從這裡開始~)

#已有材料 Partek裡的STAR完的BAM&BAI, reference genome fasta

#移到WSL本地加快速度
mv "/mnt/c/Users/ASUS/Documents/碩班/EXP/15 NGS/3_HNH3FDSX5_L4.bam" ~/
cd ~

#排序 BAM + 建立 index
samtools sort \
    -@ 4 \                         # 使用 4 個 CPU 線程
    -m 2G \                        # 每個線程分配 2GB RAM
    -T /tmp/17_HNH3FDSX5_sort \    # 暫存檔位置
    --write-index \                 # 排序完成後自動生成 .bai 索引
    -o 17_HNH3FDSX5_L4.sort.bam \  # 輸出排序後 BAM
    17_HNH3FDSX5_L4.bam            # 輸入 BAM



#加入Read Group AddOrReplaceReadGroups 
#填入sample/library/platform等information，GATK需要RG訊息區分sample/library/platform
gatk AddOrReplaceReadGroups \
    -I ~/3_HNH3FDSX5_L4_sort.bam \
    -O ~/3_HNH3FDSX5_L4_rg.bam \
    -RGID 3_HNH3FDSX5_L4 -RGLB H1993_lib -RGPL ILLUMINA -RGPU 3_HNH3FDSX5_L4 -RGSM P 
samtools view -H 3_HNH3FDSX5_L4_rg.bam | grep '@RG'     #檢查Read Group



#MarkDuplicates 
#去除PCR重複
gatk MarkDuplicates  --java-options "-Xmx8g -XX:ParallelGCThreads=4" -I ~/3_HNH3FDSX5_L4_rg.bam  -O ~/3_HNH3FDSX5_L4_dedup.bam -M ~/3_HNH3FDSX5_L4_metrics.txt
samtools index 3_HNH3FDSX5_L4_dedup.bam
less ~/3_HNH3FDSX5_L4_metrics.txt #檢查

#| 欄位                  | 說明                       |
#| ------------------- | ------------------------ |
#| LIBRARY             | 標示哪個 library             |
#| UNMAPPED_READS      | 沒對到 reference 的 read 數量  |
#| UNPAIRED_READS      | 單端 read 數量               |
#| READ_PAIRS          | 總 read pairs             |
#| UNMARKED_READS      | 標記 duplicate 之前的 read 數量 |
#| DUPLICATE_READS     | 被標記為 duplicate 的 read 數量 |
#| PERCENT_DUPLICATION | duplicate 百分比 → 最重要指標    |  <5-10%是一般正常RNA-seq library



#SplitNCigarReads 
#RNA-seq reads可能跨exon，產生CIGAR中有N，HaplotypeCaller要先拆，這步很久
gatk SplitNCigarReads --java-options "-Xmx6g -XX:ParallelGCThreads=3" -R ~/reference/hg38_ucsc/hg38.fa -I ~/3_HNH3FDSX5_L4_dedup.bam -O ~/3_HNH3FDSX5_L4_split.bam
samtools sort -@ 4 -m 2G --write-index -o 3_HNH3FDSX5_L4_split.sorted.bam 3_HNH3FDSX5_L4_split.bam




#6️⃣ BQSR（Base Quality Score Recalibration）

#下載dbSNP known sites (UCSC/chr ver., hg38) (第二次之後可跳過)
#for BQSR (Base Quality Score Recalibration)
cd ~/reference
wget http://ftp.ncbi.nlm.nih.gov/snp/organisms/human_9606_b151_GRCh38p7/VCF/GATK/00-All.vcf.gz
wget http://ftp.ncbi.nlm.nih.gov/snp/organisms/human_9606_b151_GRCh38p7/VCF/GATK/00-All.vcf.gz.tbi
bcftools index -f 00-All.vcf.gz

#檢查資料頭尾是否完整
bcftools view -h ~/reference/00-All.vcf.gz | head
####fileformat=VCFv4.2
##dbSNP_BUILD_ID=151
##reference=GRCh38
bcftools view ~/reference/00-All.vcf.gz | tail
###看到變異資料###

#檢查染色體格式 #要轉
samtools view -H ~/3_HNH3FDSX5_L4_split.sorted.bam | grep "@SQ" | head
bcftools view -h 00-All.vcf.gz | grep contig | head
#看到SN:chr1是chr版，看到SN:1是no-chr版，不一致的話要轉

nano chr_map.txt #建染色體對照表檔案 (第二次之後可跳過)
