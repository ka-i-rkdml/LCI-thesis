awk -F'|' -v genes="$GENE" '{if($4 ~ genes) print $4}' | sort | uniq


# 篩選基因，不管 Impact (所有目標基因的R-only變異)
bcftools query -f '%CHROM\t%POS\t%REF\t%ALT\t%INFO/ANN\n' diff_CriR1P/0000.vcf \
| awk -F'\t' -v genes="$GENE" '{
    split($5,a,",");
    for(i in a){
        split(a[i],f,"|");
        gene=f[4]; ann_type=f[2]; impact=f[3]; protein=f[11];
        if(gene ~ ("^(" genes ")$")){
            key = $1"-"$2"-"$3"-"$4      # CHROM-POS-REF-ALT 作為 key
            if(!seen[key]++){
                print $1"\t"$2"\t"$3"\t"$4"\t"gene"\t"ann_type"\t"impact"\t"protein
            }
        }
    }
}' > CriR1_specific_genes_all.tsv

# HIGH/MODERATE
awk -F'\t' '{if($7=="HIGH" || $7=="MODERATE" || $7=="LOW") print $0}' CriR1_specific_genes_all.tsv > CriR1_specific_genes_strong.tsv

#計算variant數量
bcftools view -H file.vcf \
| awk '{ key = $1"-"$2"-"$4"-"$5; if(!seen[key]++) count++ } END{print count}'

#想直接算不產生中間檔案紀錄
bcftools query -f '%CHROM\t%POS\t%REF\t%ALT\t%INFO/ANN\n' diff_CriR1P/0000.vcf \
| awk -F'\t' -v genes="$GENE" '
{
    split($5,a,",");
    for(i in a){
        split(a[i],f,"|");
        if(f[4] ~ ("^(" genes ")$")){
            key=$1"-"$2"-"$3"-"$4;
            if(!seen[key]++) count++
        }
    }
}
END{print count}
'
