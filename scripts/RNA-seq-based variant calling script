#存檔：Ctrl+O → Enter → Ctrl+X



#轉換染色體格式
bcftools annotate \
  --rename-chrs chr_map.txt \
  00-All.vcf.gz \
  -Oz -o 00-All.chr.vcf.gz
bcftools index -f 00-All.chr.vcf.gz
tabix -p vcf 00-All.chr.vcf.gz #也可用tabix產生.tbi
bcftools view -h 00-All.chr.vcf.gz | grep contig | head
##contig=<ID=chr1>
##contig=<ID=chr2>
...



#Base Quality Score Recalibration (BQSR)
#修正測序品質偏差，提升變異檢測精確度
gatk --java-options "-Xmx10g -XX:ParallelGCThreads=8" BaseRecalibrator -I ~/3_HNH3FDSX5_L4_split.sorted.bam -R ~/reference/hg38_ucsc/hg38.fa  --known-sites ~/reference/00-All.chr.vcf.gz -O ~/3_HNH3FDSX5_L4_recal_data.table
gatk --java-options "-Xmx8g -XX:ParallelGCThreads=6" ApplyBQSR -R ~/reference/hg38_ucsc/hg38.fa -I ~/3_HNH3FDSX5_L4_split.sorted.bam --bqsr-recal-file ~/3_HNH3FDSX5_L4_recal_data.table -O ~/3_HNH3FDSX5_L4_BQSR.bam
samtools index 3_HNH3FDSX5_L4_BQSR.bam


#裝libgomp加速GATK (第二次之後不用)
sudo apt update
sudo apt install libgomp1





#7️⃣ Variant Calling (HaplotypeCaller)

screen -S gatk #先貼這個然後gatk haplotypecaller一次跑
screen -r gatk #中斷的時候可救電腦


gatk --java-options "-Xmx10g -XX:ParallelGCThreads=8" HaplotypeCaller -R ~/reference/hg38_ucsc/hg38.fa -I ~/3_HNH3FDSX5_L4_BQSR.bam -O ~/3_HNH3FDSX5_L4_raw.vcf.gz --dont-use-soft-clipped-bases true --standard-min-confidence-threshold-for-calling 20  --min-base-quality-score 20 -ERC GVCF -native-pair-hmm-threads 8
#-ERC GVCF → 生成 GVCF，可後續做 multi-sample joint calling
#--dont-use-soft-clipped-bases true ⭐⭐⭐，👉RNA-seq 必開，因為exon–exon junction 會產生 soft-clip，不關會產生一堆假變異
#--standard-min-confidence-threshold-for-calling 20，預設值，腫瘤 RNA-seq 很合理，不用改
#-ERC GVCF， GVCF檔 (genomic VCF)，不只記變異，沒變異的地方也會記，算是半成品草稿，保留不確定資訊如likelihood, confidence, genotype機率，定位為中繼格式



#GenotypeGVCF>>>VCF
#正式判定基因型+補annotation(QD, FS...)
gatk --java-options "-Xmx8g -XX:ParallelGCThreads=6" GenotypeGVCFs \
  -R ~/reference/hg38_ucsc/hg38.fa \
  -V ~/3_HNH3FDSX5_L4_raw.vcf.gz \
  -O ~/3_HNH3FDSX5_L4_genotyped.vcf.gz





#8️⃣ Variant Filtering

#確認vcf有的欄位
bcftools view -h 3_HNH3FDSX5_L4_genotyped.vcf.gz | grep INFO
##應該會看到QD,FS,SOR,MQ,DP
##INFO=<ID=AC,Number=A,Type=Integer,Description="Allele count in genotypes, for each ALT allele, in the same order as listed">
##INFO=<ID=AF,Number=A,Type=Float,Description="Allele Frequency, for each ALT allele, in the same order as listed">
##INFO=<ID=AN,Number=1,Type=Integer,Description="Total number of alleles in called genotypes">
##INFO=<ID=BaseQRankSum,Number=1,Type=Float,Description="Z-score from Wilcoxon rank sum test of Alt Vs. Ref base qualities">
##INFO=<ID=DP,Number=1,Type=Integer,Description="Approximate read depth; some reads may have been filtered">
##INFO=<ID=END,Number=1,Type=Integer,Description="Stop position of the interval">
##INFO=<ID=ExcessHet,Number=1,Type=Float,Description="Phred-scaled p-value for exact test of excess heterozygosity">
##INFO=<ID=FS,Number=1,Type=Float,Description="Phred-scaled p-value using Fisher's exact test to detect strand bias">
##INFO=<ID=InbreedingCoeff,Number=1,Type=Float,Description="Inbreeding coefficient as estimated from the genotype likelihoods per-sample when compared against the Hardy-Weinberg expectation">
##INFO=<ID=MLEAC,Number=A,Type=Integer,Description="Maximum likelihood expectation (MLE) for the allele counts (not necessarily the same as the AC), for each ALT allele, in the same order as listed">
##INFO=<ID=MLEAF,Number=A,Type=Float,Description="Maximum likelihood expectation (MLE) for the allele frequency (not necessarily the same as the AF), for each ALT allele, in the same order as listed">
##INFO=<ID=MQ,Number=1,Type=Float,Description="RMS Mapping Quality">
##INFO=<ID=MQRankSum,Number=1,Type=Float,Description="Z-score From Wilcoxon rank sum test of Alt vs. Ref read mapping qualities">
##INFO=<ID=QD,Number=1,Type=Float,Description="Variant Confidence/Quality by Depth">
##INFO=<ID=RAW_MQandDP,Number=2,Type=Integer,Description="Raw data (sum of squared MQ and total depth) for improved RMS Mapping Quality calculation. Incompatible with deprecated RAW_MQ formulation.">
##INFO=<ID=ReadPosRankSum,Number=1,Type=Float,Description="Z-score from Wilcoxon rank sum test of Alt vs. Ref read position bias">
##INFO=<ID=SOR,Number=1,Type=Float,Description="Symmetric Odds Ratio of 2x2 contingency table to detect strand bias">


# 設定路徑
REF=~/reference/hg38_ucsc/hg38.fa
INPUT_VCF=~/3_HNH3FDSX5_L4_genotyped.vcf.gz
OUTDIR=~/
MEM=10g

##縮寫定義
#QD(Quality/Depth)=QUAL/DP 變異可信度/覆蓋深度
#FS(Fisher Strand Bias) 正負股reads分布是否不均
#MQ(Mapping Quality) Reads對到reference的可信度平均
#MQRankSum(Mapping Quality Rank Sum Test) 有變異的reads比較沒變異的reads的MQ，所以如果只有爛mapping的reads才支持變異就很糟，負值為alt reads較差
#ReadPosRankSum(Read Position Rank Sum) 變異出現在read的哪裡，如果都出現在read末端的話很可以甚至很糟

########################################
# 1️⃣ 分 SNP 與 Indel
########################################
gatk --java-options "-Xmx$MEM" SelectVariants \
  -R $REF \
  -V $INPUT_VCF \
  -select-type SNP \
  -O $OUTDIR/snps.vcf.gz

gatk --java-options "-Xmx$MEM" SelectVariants \
  -R $REF \
  -V $INPUT_VCF \
  -select-type INDEL \
  -O $OUTDIR/indels.vcf.gz

########################################
# 2️⃣ SNP 過濾
# 建議閾值: QD<2 || FS>30 || MQ<40 || MQRankSum<-12.5 || ReadPosRankSum<-8
########################################
gatk --java-options "-Xmx$MEM" VariantFiltration \
  -R $REF \
  -V $OUTDIR/snps.vcf.gz \
  -O $OUTDIR/snps.filtered.vcf.gz \
  --filter-name "QD2" --filter-expression "vc.hasAttribute('QD') && vc.getAttribute('QD') < 2.0" \
  --filter-name "FS30" --filter-expression "vc.hasAttribute('FS') && vc.getAttribute('FS') > 30.0" \
  --filter-name "MQ40" --filter-expression "vc.hasAttribute('MQ') && vc.getAttribute('MQ') < 40.0" \
  --filter-name "MQRankSum-12.5" --filter-expression "vc.hasAttribute('MQRankSum') && vc.getAttribute('MQRankSum') < -12.5" \
  --filter-name "ReadPosRankSum-8" --filter-expression "vc.hasAttribute('ReadPosRankSum') && vc.getAttribute('ReadPosRankSum') < -8.0"

########################################
# 3️⃣ Indel 過濾
# 建議閾值: QD<2 || FS>200 || ReadPosRankSum<-20
########################################
gatk --java-options "-Xmx$MEM" VariantFiltration \
  -R $REF \
  -V $OUTDIR/indels.vcf.gz \
  -O $OUTDIR/indels.filtered.vcf.gz \
  --filter-name "QD2" --filter-expression "vc.hasAttribute('QD') && vc.getAttribute('QD') < 2.0" \
  --filter-name "FS200" --filter-expression "vc.hasAttribute('FS') && vc.getAttribute('FS') > 200.0" \
  --filter-name "ReadPosRankSum-20" --filter-expression "vc.hasAttribute('ReadPosRankSum') && vc.getAttribute('ReadPosRankSum') < -20.0"

########################################
# 4️⃣ 合併 SNP + Indel
########################################
gatk MergeVcfs \
  -I $OUTDIR/snps.filtered.vcf.gz \
  -I $OUTDIR/indels.filtered.vcf.gz \
  -O $OUTDIR/merged.filtered.vcf.gz

########################################
# 5️⃣ MLEAF 過濾 + 保留 PASS
# 保留所有 ALT allele MLEAF >=0.05，可改為任一 allele >=0.05 用 ||
########################################
bcftools view -f PASS -i 'INFO/MLEAF[0]>=0.05 && INFO/MLEAF[1]>=0.05' \
  -Oz -o $OUTDIR/filtered.final.vcf.gz \
  $OUTDIR/merged.filtered.vcf.gz

# 建立 index
bcftools index $OUTDIR/filtered.final.vcf.gz

########################################
# 6️⃣ 檢查結果
########################################
bcftools query -f '%CHROM\t%POS\t%MLEAF\n' $OUTDIR/filtered.final.vcf.gz | head

#SNP/Indel 分開過濾，閾值符合推薦。
#只保留 PASS variant。
#MLEAF 過濾整合在一次 bcftools 命令，簡化流程。
#支援多 ALT allele，可輕鬆改 [0] [1] [2] ... 或改 || 條件。

