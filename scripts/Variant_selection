#!/bin/bash
# =========================================================
# Script: compare_resistant_parental.sh
# Purpose: Compare Resistant (R) vs Parental (P) VCFs, extract gene-specific variants and count impacts
# Author: Ka-I Li
# =========================================================

# ------------------------
# 1️⃣ Define input VCFs and output directories
# ------------------------
R_VCF=~/ann/R.ann.vcf.gz       # Resistant
P_VCF=~/ann/P.ann.vcf.gz       # Parental
OUTDIR=~/ann/diff_RP
mkdir -p $OUTDIR

# ------------------------
# 2️⃣ Index VCFs with bgzip/tabix if not already
# ------------------------
for vcf in $R_VCF $P_VCF; do
    if [[ ! -f "${vcf}.tbi" ]]; then
        bgzip -c $vcf > ${vcf}.gz
        tabix -p vcf ${vcf}.gz
    fi
done

# ------------------------
# 3️⃣ Extract R-specific variants (private to R) using bcftools isec
# Output files:
#   0000.vcf -> private to R
#   0001.vcf -> private to P
#   0002.vcf -> shared variants
#   0003.vcf -> shared variants (P perspective)
# ------------------------
bcftools isec $R_VCF $P_VCF -p $OUTDIR

# ------------------------
# 4️⃣ Define target genes and control genes
# ------------------------
GENE="MET|EGFR|KRAS|BRAF|ERBB2|ERBB3|PIK3CA|AKT1|AKT2|AKT3|ALK|AR|ARAF|CDK4|CDKN2A|CHEK2|CTNNB1|ERBB4|ESR1|FGFR1|FGFR2|FGFR3|FGFR4|FLT3|GNA11|GNAQ|GNAS|HRAS|IDH1|IDH2|KIT|MAP2K1|MAP2K2|MTOR|NRAS|NTRK1|NTRK2|NTRK3|PDGFRA|PTEN|RAF1|RET|ROS1|SMO|TP53|CD274|RSPO2|RSPO3|NRG1|NUTM1"
CTRLGENE="TP53|STK11"

# ------------------------
# 5️⃣ Extract R-specific variants for target genes
# ------------------------
bcftools query -f '%CHROM\t%POS\t%REF\t%ALT\t%INFO/ANN\n' $OUTDIR/0000.vcf \
| awk -F'\t' -v genes="$GENE" '
{
    split($5, a, ",");
    for(i in a){
        split(a[i], f, "|");
        gene=f[4]; ann_type=f[2]; impact=f[3]; protein=f[11];
        if(gene ~ ("^(" genes ")$")){
            key = $1"-"$2"-"$3"-"$4
            if(!seen[key]++){
                print $1"\t"$2"\t"$3"\t"$4"\t"gene"\t"ann_type"\t"impact"\t"protein
            }
        }
    }
}' > $OUTDIR/R_specific_genes_all.tsv

# ------------------------
# 6️⃣ Filter HIGH/MODERATE/LOW impact variants
# ------------------------
awk -F'\t' '{if($7=="HIGH" || $7=="MODERATE" || $7=="LOW") print $0}' \
    $OUTDIR/R_specific_genes_all.tsv > $OUTDIR/R_specific_genes_strong.tsv

# ------------------------
# 7️⃣ Count unique variants (CHROM-POS-REF-ALT)
# ------------------------
echo "Total unique R-specific variants in target genes:"
bcftools query -f '%CHROM\t%POS\t%REF\t%ALT\t%INFO/ANN\n' $OUTDIR/0000.vcf \
| awk -F'\t' -v genes="$GENE" '
{
    split($5,a,",");
    for(i in a){
        split(a[i],f,"|");
        if(f[4] ~ ("^(" genes ")$")){
            key=$1"-"$2"-"$3"-"$4;
            if(!seen[key]++) count++
        }
    }
}
END{print count}
'

# ------------------------
# 8️⃣ Optional: Inspect gene distribution
# ------------------------
echo "R-specific gene distribution (top 10):"
bcftools query -f '%ANN\n' $OUTDIR/0000.vcf \
| awk -F'|' -v genes="$GENE" '{if($4 ~ genes) print $4}' \
| sort | uniq -c | sort -nr | head
